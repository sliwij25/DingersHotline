# Copy this file to .env and fill in your keys

# Anthropic (optional — only needed if switching back to Claude models)
ANTHROPIC_API_KEY=

# The Odds API — HR prop lines (free tier: 500 req/month at the-odds-api.com)
ODDS_API_KEY=

# BallparkPal subscription — matchup grades, park-adjusted HR%, weather
BALLPARKPAL_EMAIL=
BALLPARKPAL_PASSWORD=

# OpenWeatherMap — live weather fallback when BallparkPal is unavailable
# Free tier: 1000 calls/day at openweathermap.org
OPENWEATHER_API_KEY=
